{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "skipLibCheck": true,
    "strictNullChecks": true,

    "types": ["node", "vite-plus/client", "vite-plugin-pwa/client", "unplugin-icons/types/react"],
    "paths": {
      "@/*": ["./src/*"]
    },
    // TanStack Start: Enabling `verbatimModuleSyntax` can result in server bundles leaking into client bundles. It is recommended to keep this option disabled.
    "verbatimModuleSyntax": false,

    // paraglide js
    "allowJs": true,
    "noEmit": true
  }
}
