{
  "name": "smart-tavern",
  "version": "0.0.0",
  "description": "A fork of SillyTavern.",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/MioYiSama/SmartTavern.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "preview": "vp preview",
    "check": "vp check",
    "fmt": "vp fmt",
    "test": "vp test",
    "clean": "rm -rf .output .tanstack node_modules/.vite node_modules/.vite-temp node_modules/.nitro node_modules/.cache",
    "build": "pnpm run clean && vp build",
    "build:deno": "NITRO_PRESET=deno pnpm run build",
    "build:bun": "NITRO_PRESET=bun pnpm run build",
    "build:docker": "docker build -f docker/Dockerfile -t mioyisama/smart-tavern:latest .",
    "build:docker:deno": "docker build -f docker/Dockerfile.deno -t mioyisama/smart-tavern:deno .",
    "build:docker:bun": "docker build -f docker/Dockerfile.bun -t mioyisama/smart-tavern:bun .",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "patch:openrouter": "node scripts/patch-openrouter-sdk.mjs",
    "pwa-assets": "pwa-assets-generator --preset minimal-2023 public/logo.png",
    "auth": "pnpm dlx auth@latest generate --yes --output src/db"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@electric-sql/pglite": "^0.5.3",
    "@electric-sql/pglite-pgvector": "^0.0.4",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/ai": "^0.39.0",
    "@tanstack/ai-anthropic": "^0.15.13",
    "@tanstack/ai-gemini": "^0.19.0",
    "@tanstack/ai-openai": "^0.15.10",
    "@tanstack/ai-openrouter": "^0.15.6",
    "@tanstack/ai-react": "^0.16.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "better-auth": "^1.6.23",
    "drizzle-orm": "1.0.0-rc.4",
    "katex": "^0.17.0",
    "nitro": "3.0.260610-beta",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "srvx": "^0.11.18",
    "streamdown": "^2.5.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@catppuccin/daisyui": "^2.1.1",
    "@iconify-json/lucide": "^1.2.115",
    "@iconify-json/simple-icons": "^1.2.88",
    "@inlang/cli": "^3.1.14",
    "@inlang/paraglide-js": "^2.20.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/react-ai-devtools": "^0.2.63",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "daisyui": "^5.6.6",
    "drizzle-kit": "1.0.0-rc.4",
    "tailwindcss": "^4.3.2",
    "typescript": "7.0.1-rc",
    "unplugin-icons": "^23.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "^0.2.1",
    "workbox-build": "^7.4.1",
    "workbox-window": "7.4.1"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
